# Devin API key for creating remediation sessions.
DEVIN_API_KEY=$DEVIN_API_KEY

# GitHub personal access token with 'repo' scope.
GITHUB_TOKEN=$GITHUB_TOKEN

# Target GitHub repository in "owner/repo" format.
GITHUB_REPO=$GITHUB_REPO

# Shared secret used to verify GitHub webhook HMAC-SHA256 signatures.
# This value acts as the CSRF protection for the POST /webhook endpoint:
# without it an attacker cannot forge a valid request. Keep it long and
# random (e.g. `openssl rand -hex 32`). Must match the secret configured
# in the GitHub webhook settings.
WEBHOOK_SECRET=$WEBHOOK_SECRET

# Optional – Devin API base URL (default shown below).
DEVIN_BASE_URL=https://api.devin.ai/v1
